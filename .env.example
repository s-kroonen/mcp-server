# ── Auth ─────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
MCP_API_KEY=vervang_dit_met_een_sterk_wachtwoord

# ── SMTP (Mailcow) ────────────────────────────────────
SMTP_HOST=mail.kroon-en.nl
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=storm@kroon-en.nl
SMTP_PASS=jouw_mailcow_wachtwoord

# ── NAS file access ───────────────────────────────────
# Paden zoals ze BINNEN de container zichtbaar zijn
NAS_ALLOWED_PATHS=/mnt/nas/stage,/mnt/nas/documents

# Volume mounts (host pad → container pad)
# Pas de host-paden aan naar jouw NAS mount points
NAS_MOUNT_1=/mnt/nas/stage
NAS_MOUNT_1_TARGET=/mnt/nas/stage
NAS_MOUNT_2=/mnt/nas/documents
NAS_MOUNT_2_TARGET=/mnt/nas/documents
