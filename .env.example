# ── MCP Server ───────────────────────────────────────
# Public URL of this MCP server (used in OAuth metadata)
SERVER_URL=https://mcp.kroon-en.nl

# ── Keycloak (Auth Server) ────────────────────────────
# Public URL of Keycloak — shown in OAuth discovery docs (must be reachable by the client browser)
KEYCLOAK_PUBLIC_URL=https://auth.kroon-en.nl
KEYCLOAK_REALM=storm

# Keycloak admin credentials (first boot only)
KC_ADMIN_USER=admin
KC_ADMIN_PASS=CHANGE_ME_STRONG_PASSWORD

# OAuth client credentials for token introspection
# Must match the secret in keycloak/realm-export.json
OAUTH_CLIENT_ID=storm-mcp-server
OAUTH_CLIENT_SECRET=GENERATE_WITH_openssl_rand_hex_32

# ── SMTP (Mailcow) ────────────────────────────────────
SMTP_HOST=mail.kroon-en.nl
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=storm@kroon-en.nl
SMTP_PASS=jouw_mailcow_wachtwoord
